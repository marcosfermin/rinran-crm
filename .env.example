# Puerto donde correrá el frontend (acceso desde el navegador)
FRONTEND_PORT=3000

# ──────────────────────────────────────────────
# Autenticación CRM
# ──────────────────────────────────────────────
JWT_SECRET=rinran-secret-change-me
ADMIN_EMAIL=admin@rinran.com
ADMIN_PASSWORD=changeme123

# ──────────────────────────────────────────────
# WAHA Pro (WhatsApp)
# ──────────────────────────────────────────────

# URL interna — el backend habla con WAHA dentro de Docker
OPENWA_URL=http://waha:3000

# API Key — debe coincidir con WAHA_API_KEY de abajo
OPENWA_API_KEY=rinran-waha-key-change-me

# Clave de autenticación de WAHA (la usa el contenedor waha y el backend)
WAHA_API_KEY=rinran-waha-key-change-me

# Credenciales del dashboard web de WAHA (http://servidor:3001/dashboard)
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=rinran-dashboard-2024

# CORS
CORS_ORIGIN=*
