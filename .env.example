# Puerto donde correrá el frontend (acceso desde el navegador)
FRONTEND_PORT=3000

# ──────────────────────────────────────────────
# Autenticación
# ──────────────────────────────────────────────

# Clave secreta para firmar los JWT — CAMBIAR en producción
JWT_SECRET=rinran-secret-change-me

# Credenciales del usuario admin (se crean la primera vez que el backend arranca)
ADMIN_EMAIL=admin@rinran.com
ADMIN_PASSWORD=changeme123

# ──────────────────────────────────────────────
# Evolution API (WhatsApp)
# ──────────────────────────────────────────────

# URL pública de Evolution API (para QR code y webhooks desde WhatsApp)
# Ejemplo: https://evolution.tudominio.com
EVOLUTION_SERVER_URL=http://localhost:8081

# URL interna que usa el backend para hablar con Evolution API (dentro de Docker)
EVOLUTION_URL=http://evolution:8080

# API Key de Evolution API — debe coincidir con lo que configurés en el dashboard
EVOLUTION_API_KEY=rinran-evo-key-change-me

# Nombre de la instancia de Evolution API (opcional — se autodetecta si está vacío)
EVOLUTION_INSTANCE=

# CORS (opcional — por defecto permite todo)
CORS_ORIGIN=*
