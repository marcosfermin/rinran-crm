# Puerto donde correrá el frontend (acceso desde el navegador)
FRONTEND_PORT=3000

# ──────────────────────────────────────────────
# Meta WhatsApp Business Cloud API
# ──────────────────────────────────────────────

# Token de acceso permanente de tu App de Meta
WA_ACCESS_TOKEN=your_permanent_access_token_here

# ID del número de teléfono registrado en WhatsApp Business
WA_PHONE_NUMBER_ID=your_phone_number_id_here

# Token que usas al configurar el webhook en Meta (lo eliges tú)
WA_VERIFY_TOKEN=rinran_secret_token_2026

# CORS (opcional — por defecto permite todo)
CORS_ORIGIN=*
