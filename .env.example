# ──────────────────────────────────────────────
# Rinran CRM — Variables de entorno
# Copia este archivo como .env y ajusta los valores,
# o ejecuta ./setup.sh para configuración automática.
# ──────────────────────────────────────────────

# Puerto de acceso al CRM desde el navegador
FRONTEND_PORT=3000

# ── Autenticación CRM ──────────────────────────
# Secreto para firmar JWT (genera con: openssl rand -hex 32)
JWT_SECRET=cambia-esto-por-un-secreto-seguro

# Usuario administrador (se crea solo si la base de datos está vacía)
ADMIN_EMAIL=admin@miempresa.com
ADMIN_PASSWORD=contraseña-segura

# ── WAHA (WhatsApp HTTP API) ───────────────────
# URL interna — no cambiar si usas Docker Compose
OPENWA_URL=http://waha:3000

# API Key — debe ser igual en ambas variables
# Genera con: openssl rand -hex 32
OPENWA_API_KEY=cambia-esto
WAHA_API_KEY=cambia-esto

# Dashboard web de WAHA (accesible en http://servidor:3001/dashboard)
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=contraseña-dashboard

# ── CORS ──────────────────────────────────────
CORS_ORIGIN=*
