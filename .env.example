# Puerto donde correrá el frontend (acceso desde el navegador)
FRONTEND_PORT=3000

# ──────────────────────────────────────────────
# Autenticación
# ──────────────────────────────────────────────

# Clave secreta para firmar los JWT — CAMBIAR en producción
JWT_SECRET=rinran-secret-change-me

# Credenciales del usuario admin (se crean la primera vez que el backend arranca)
# Si ya existe un usuario en la base de datos, estos valores se ignoran
ADMIN_EMAIL=admin@rinran.com
ADMIN_PASSWORD=changeme123

# ──────────────────────────────────────────────
# OpenWA Server
# ──────────────────────────────────────────────

# URL base del servidor OpenWA (sin slash final)
# Ejemplo: http://192.168.1.100:8080  o  https://openwa.tudominio.com
OPENWA_URL=http://localhost:8080

# API Key del servidor OpenWA (si lo configuraste con autenticación)
# Dejar vacío si no tiene autenticación
OPENWA_API_KEY=

# CORS (opcional — por defecto permite todo)
CORS_ORIGIN=*
